<Window
    x:Class="LinguaMesh.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LinguaMesh">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="24">
            <TextBlock Text="LinguaMesh" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Provider profile" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ComboBox x:Name="ModelSelector" Header="Model" />
            <TextBox x:Name="SourceText" Header="Source text" AcceptsReturn="True" MinHeight="120" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="TranslateButton" Content="Translate" Click="TranslateButton_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" IsEnabled="False" />
                <Button Content="中文" Click="ChineseLocaleButton_Click" />
                <Button Content="English" Click="EnglishLocaleButton_Click" />
            </StackPanel>
            <TextBlock x:Name="StatusText" Text="Ready" AutomationProperties.LiveSetting="Polite" />
            <TextBox x:Name="OutputText" Header="Translation" IsReadOnly="True" AcceptsReturn="True" MinHeight="120" />
            <TextBlock Text="Diagnostics" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="DiagnosticsText" Text="Core: ABI 1 / Protocol 1 / fake provider" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Window>
